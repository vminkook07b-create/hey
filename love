<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Happy 18th Birthday Babe 💙</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <!-- Slide 1: Welcome Page -->
    <div class="slide slide-1">
        <div class="hearts-container">
            <span class="floating-heart">❤️</span>
            <span class="floating-heart">💙</span>
            <span class="floating-heart">✨</span>
            <span class="floating-heart">🌸</span>
            <span class="floating-heart">💕</span>
        </div>
        <div class="content">
            <h1 class="main-title">Hey Love 💙</h1>
            <p class="subtitle">Something special awaits you...</p>
            <button class="next-btn" onclick="goToSlide(2)">Click Here ✨</button>
            <div class="emoji-animation">
                <span class="emoji">🎉</span>
                <span class="emoji">🌸</span>
                <span class="emoji">💫</span>
                <span class="emoji">🦋</span>
            </div>
        </div>
    </div>

    <!-- Slide 2: Happy Birthday -->
    <div class="slide slide-2">
        <div class="hearts-container">
            <span class="floating-heart">❤️</span>
            <span class="floating-heart">💙</span>
            <span class="floating-heart">✨</span>
            <span class="floating-heart">🌸</span>
            <span class="floating-heart">💕</span>
        </div>
        <div class="content">
            <h1 class="birthday-title">Happy 18th Birthday Babe! 🎂</h1>
            <p class="emoji-text">
                <span class="emoji-large">🎉</span>
                <span class="emoji-large">💙</span>
                <span class="emoji-large">🌟</span>
            </p>
            <div class="button-container">
                <button class="nav-btn" onclick="goToSlide(1)">← Back</button>
                <button class="nav-btn" onclick="goToSlide(3)">Next →</button>
            </div>
        </div>
    </div>

    <!-- Slide 3: 18 Messages (Envelopes) -->
    <div class="slide slide-3">
        <div class="hearts-container">
            <span class="floating-heart">❤️</span>
            <span class="floating-heart">💙</span>
            <span class="floating-heart">✨</span>
            <span class="floating-heart">🌸</span>
            <span class="floating-heart">💕</span>
        </div>
        <div class="content">
            <h2 class="slide-title">18 Special Messages For You 💌</h2>
            <div class="envelopes-grid" id="envelopesGrid">
                <!-- Envelopes will be generated by JavaScript -->
            </div>
            <div class="button-container">
                <button class="nav-btn" onclick="goToSlide(2)">← Back</button>
                <button class="nav-btn" onclick="goToSlide(4)">Next →</button>
            </div>
        </div>
    </div>

    <!-- Slide 4: Flowers & Compliments -->
    <div class="slide slide-4">
        <div class="hearts-container">
            <span class="floating-heart">❤️</span>
            <span class="floating-heart">💙</span>
            <span class="floating-heart">✨</span>
            <span class="floating-heart">🌸</span>
            <span class="floating-heart">💕</span>
        </div>
        <div class="flowers-background">
            <div class="flower">🌹</div>
            <div class="flower">🌷</div>
            <div class="flower">🌺</div>
            <div class="flower">🌼</div>
            <div class="flower">🌸</div>
        </div>
        <div class="content">
            <h2 class="slide-title">You're Beautiful As These Flowers 🌹</h2>
            <div class="compliments-container">
                <p class="compliment">Just like these flowers, you bring color to everyone's world</p>
                <p class="compliment">Your beauty radiates from within, just like the petals of these blooms</p>
                <p class="compliment">Each flower is unique, just like you - absolutely one of a kind</p>
            </div>
            <div class="button-container">
                <button class="nav-btn" onclick="goToSlide(3)">← Back</button>
                <button class="nav-btn" onclick="goToSlide(5)">Next →</button>
            </div>
        </div>
    </div>

    <!-- Slide 5: Music Playlist -->
    <div class="slide slide-5">
        <div class="hearts-container">
            <span class="floating-heart">❤️</span>
            <span class="floating-heart">💙</span>
            <span class="floating-heart">✨</span>
            <span class="floating-heart">🌸</span>
            <span class="floating-heart">💕</span>
        </div>
        <div class="content">
            <h2 class="slide-title">Your Birthday Playlist 🎵</h2>
            <div class="playlist-container">
                <div class="song-item" onclick="playSong(0)">
                    <span class="song-icon">🎵</span>
                    <span class="song-name">Enchanted - Taylor Swift</span>
                </div>
                <div class="song-item" onclick="playSong(1)">
                    <span class="song-icon">🎵</span>
                    <span class="song-name">Lover - Taylor Swift</span>
                </div>
                <div class="song-item" onclick="playSong(2)">
                    <span class="song-icon">🎵</span>
                    <span class="song-name">Now That I Found You - Ella Bright</span>
                </div>
                <div class="song-item" onclick="playSong(3)">
                    <span class="song-icon">🎵</span>
                    <span class="song-name">West Coast - Lana Del Rey</span>
                </div>
                <div class="song-item" onclick="playSong(4)">
                    <span class="song-icon">🎵</span>
                    <span class="song-name">Art Deco - Lana Del Rey</span>
                </div>
            </div>
            <div class="player" id="musicPlayer">
                <p>Click a song to play</p>
            </div>
            <div class="button-container">
                <button class="nav-btn" onclick="goToSlide(4)">← Back</button>
                <button class="nav-btn" onclick="goToSlide(6)">Next →</button>
            </div>
        </div>
    </div>

    <!-- Slide 6: 100 Love Messages -->
    <div class="slide slide-6">
        <div class="hearts-container">
            <span class="floating-heart">❤️</span>
            <span class="floating-heart">💙</span>
            <span class="floating-heart">✨</span>
            <span class="floating-heart">🌸</span>
            <span class="floating-heart">💕</span>
        </div>
        <div class="content">
            <h2 class="slide-title">100 Reasons Why You're Amazing 💕</h2>
            <div class="messages-scroll" id="messagesScroll">
                <!-- Messages will be generated by JavaScript -->
            </div>
            <div class="button-container">
                <button class="nav-btn" onclick="goToSlide(5)">← Back</button>
                <button class="nav-btn" onclick="goToSlide(7)">Next →</button>
            </div>
        </div>
    </div>

    <!-- Slide 7: Final Message -->
    <div class="slide slide-7">
        <div class="hearts-container">
            <span class="floating-heart">❤️</span>
            <span class="floating-heart">💙</span>
            <span class="floating-heart">✨</span>
            <span class="floating-heart">🌸</span>
            <span class="floating-heart">💕</span>
            <span class="floating-heart">🎂</span>
            <span class="floating-heart">🎉</span>
        </div>
        <div class="content final-message">
            <h1 class="final-title">You're The Most Amazing Person 💙</h1>
            <p class="final-subtitle">Happy Birthday!</p>
            <p class="final-declaration">I Love You So Much 🥰</p>
            <div class="celebration-emoji">
                <span>🎉</span>
                <span>💙</span>
                <span>🌟</span>
                <span>🎂</span>
                <span>💕</span>
            </div>
            <div class="button-container">
                <button class="nav-btn" onclick="goToSlide(1)">Start Over</button>
                <button class="nav-btn" onclick="goToSlide(6)">← Back</button>
            </div>
        </div>
    </div>

    <!-- Modal for Envelope Messages -->
    <div id="messageModal" class="modal">
        <div class="modal-content envelope-modal">
            <span class="close" onclick="closeModal()">&times;</span>
            <div class="envelope-open">
                <p id="modalMessage"></p>
            </div>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
